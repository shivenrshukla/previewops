# ❌ OLD (Calls your laptop)
# VITE_BRIDGE_API_URL=http://localhost:4000

# ✅ NEW (Calls the AWS Load Balancer)
# This assumes your Ingress handles paths like /api or you have a separate subdomain
# VITE_BRIDGE_API_URL=http://api-env-${BUILD_NUMBER}.previewops.local

# Preview URL for your dashboard links
VITE_PREVIEW_BASE_URL=http://env-{id}.previewops.local

# ── Bridge API (server-side, set in your EKS pod env or Jenkins credentials) ──
# Optional: enables GitHub PR enrichment (title, author, branch)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# GITHUB_REPO=my-org/my-app
